# LLM API (OpenAI-compatible)
# 可以用 OpenAI / DeepSeek / Qwen / 任何兼容接口
OPENAI_API_KEY=*** 模型选择
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=BAAI/bge-m3

# 本地 ChromaDB 存储路径
CHROMA_PERSIST_DIR=./chroma_data

# PostgreSQL（数据库同学建表后填入）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=procureai
DB_USER=procureai
DB_PASSWORD=your-d...n
# CORS 域名（前端地址，逗号分隔）
CORS_ORIGINS=http://localhost:5173,https://*.vercel.app
