# ==============================================================================
# ProcureAI Backend — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ==============================================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# ---------------------------------------------------------------------------
# CORS — comma-separated list of allowed origins + regex for Vercel deployments
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173
CORS_ORIGIN_REGEX=https://.*\\.vercel\\.app

# ---------------------------------------------------------------------------
# LLM API (OpenAI-compatible)
# Options: OpenAI / DeepSeek / Qwen / any OpenAI-compatible API
#
#   Set OPENAI_API_KEY to enable AI-powered intent parsing & ranking.
#   Without it, the system falls back to heuristic rules (still functional).
#
#   For DeepSeek (cheap, CN-friendly):
#     OPENAI_BASE_URL=https://api.deepseek.com
#     LLM_MODEL=deepseek-chat
#
#   For OpenAI:
#     OPENAI_BASE_URL=https://api.openai.com/v1
#     LLM_MODEL=gpt-4o
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# Embedding model (local, free) — used by ChromaDB for semantic search
# ---------------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-m3

# ---------------------------------------------------------------------------
# ChromaDB persistence directory
# ---------------------------------------------------------------------------
CHROMA_PERSIST_DIR=./chroma_data

# ---------------------------------------------------------------------------
# PostgreSQL（数据库同学建表后填入）
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=procureai
DB_USER=procureai
DB_PASSWORD=*** ---------------------------------------------------------------------------
